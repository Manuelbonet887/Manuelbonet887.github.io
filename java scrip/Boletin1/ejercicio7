let continuar;

for (let i = 1; i <= 10; i++) {
  continuar = confirm("Es la " + i + "ª vez que te pregunto si quieres continuar");

  if (!continuar) {
    alert("Has decidido no continuar. Programa finalizado.");
    break;
  }

  if (i === 10) {
    alert("Has llegado al máximo de intentos. Programa finalizado.");
  }
}
