let numTabla = Number(prompt("Introduce un número del 1 al 9"));

if (numTabla >= 1 && numTabla <= 9) {
  console.log("Tabla de multiplicar del " + numTabla);

  for (let i = 1; i <= 10; i++) {
    console.log(numTabla + " x " + i + " = " + (numTabla * i));
  }
} else {
  console.log("Número incorrecto. Debe estar entre 1 y 9.");
}
